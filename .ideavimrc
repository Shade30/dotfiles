" General
set scrolloff=10
set number
set showmode
set showcmd
"set clipboard+=unnamed

" Search
set ignorecase
set smartcase
set incsearch
set hlsearch

" Plugins
set surround
set highlightedyank
set easymotion
set commentary
set NERDTree
set ReplaceWithRegister
set argtextobj
set ideajoin
set idearefactormode=keep

" Handlers
sethandler <S-Tab> a:vim
sethandler <S-CR> a:vim
sethandler <C-Pageup> a:vim
sethandler <C-Pagedown> a:vim
sethandler <S-Left> a:vim
sethandler <C-Left> a:vim
sethandler <S-Up> a:vim
sethandler <C-Up> a:vim
sethandler <S-Right> a:vim
sethandler <C-Right> a:vim
sethandler <S-Down> a:vim
sethandler <C-Down> a:vim
sethandler <C-2> a:ide
sethandler <C-S-2> a:ide
sethandler <C-6> a:vim
sethandler <C-S-6> a:ide
sethandler <C-;> a:vim
sethandler <C-S-;> a:vim
sethandler <C-A> a:ide
sethandler <C-B> a:ide
sethandler <C-C> a:ide
sethandler <C-D> a:ide
sethandler <C-E> a:ide
sethandler <C-F> a:ide
sethandler <C-G> a:ide
sethandler <C-H> a:ide
sethandler <C-I> a:vim
sethandler <C-J> a:vim
sethandler <C-K> a:vim
sethandler <C-L> a:vim
sethandler <C-M> a:ide
sethandler <C-N> a:ide
sethandler <C-O> a:vim
sethandler <C-P> a:ide
sethandler <C-Q> a:ide
sethandler <C-R> a:vim
sethandler <C-S> a:ide
sethandler <C-T> a:ide
sethandler <C-U> a:ide
sethandler <C-V> a:vim
sethandler <C-W> a:vim
sethandler <C-X> a:ide
sethandler <C-Y> a:ide
sethandler <C-[> a:ide
sethandler <C-\> a:vim
sethandler <C-]> a:ide
